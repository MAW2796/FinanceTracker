@using System.Globalization
@model List<FinanceTracker.Models.Investment>

@{
    ViewData["Title"] = "Investasi";
    var totalCurrent = (decimal)ViewBag.TotalCurrentValue;
    var totalCost = (decimal)ViewBag.TotalCost;
    var totalGainLoss = totalCurrent - totalCost;
}

@section Styles {
    <link rel="stylesheet" href="~/css/wealth.css" asp-append-version="true" />
}

<div class="wealth-page">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center page-header">
        <div>
            <h2 class="fw-bold mb-0">📈 Investasi</h2>
            <div class="mt-2 d-flex flex-wrap gap-2">
                <span class="summary-pill">Total Nilai: Rp @totalCurrent.ToString("N0", new CultureInfo("id-ID"))</span>
                @if (totalGainLoss >= 0)
                {
                    <span class="summary-pill" style="background:#e8f8ee; color:#1a9e52;">Untung Rp @totalGainLoss.ToString("N0", new CultureInfo("id-ID"))</span>
                }
                else
                {
                    <span class="summary-pill" style="background:#fdeceb; color:#d6473a;">Rugi Rp @Math.Abs(totalGainLoss).ToString("N0", new CultureInfo("id-ID"))</span>
                }
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            + Tambah Investasi
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-card">
    <table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Nama</th>
            <th>Jenis</th>
            <th>Unit</th>
            <th>Avg Beli</th>
            <th>Harga Sekarang</th>
            <th>Nilai Sekarang</th>
            <th>Untung/Rugi</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                var currentValue = item.TotalUnits * item.CurrentPrice;
                var costValue = item.TotalUnits * item.AvgBuyPrice;
                var gainLoss = currentValue - costValue;
                var gainLossPercent = costValue > 0 ? (gainLoss / costValue) * 100 : 0;

                <tr>
                    <td>@item.Name</td>
                    <td><span class="badge bg-secondary">@item.Type</span></td>
                    <td>@item.TotalUnits.ToString("0.######") @item.UnitLabel</td>
                    <td>Rp @item.AvgBuyPrice.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>Rp @item.CurrentPrice.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>Rp @currentValue.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>
                        @if (gainLoss >= 0)
                        {
                            <span class="text-success">+Rp @gainLoss.ToString("N0", new CultureInfo("id-ID")) (@gainLossPercent.ToString("0.0")%)</span>
                        }
                        else
                        {
                            <span class="text-danger">-Rp @Math.Abs(gainLoss).ToString("N0", new CultureInfo("id-ID")) (@gainLossPercent.ToString("0.0")%)</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#buyModal-@item.Id">Beli</button>
                        <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#sellModal-@item.Id">Jual</button>
                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#priceModal-@item.Id">Update Harga</button>
                        <a asp-action="History" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Riwayat</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Hapus</a>
                    </td>
                </tr>

                <!-- MODAL BELI -->
                <div class="modal fade" id="buyModal-@item.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="Buy" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Beli Tambahan - @item.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Jumlah Unit</label>
                                        <input type="text" name="units" class="form-control" placeholder="Contoh: 5 atau 0.25" inputmode="decimal" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Harga per Unit</label>
                                        <input type="text" name="pricePerUnit" class="form-control buy-sell-price-input" placeholder="Harga beli" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="submit" class="btn btn-success">Simpan</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- MODAL JUAL -->
                <div class="modal fade" id="sellModal-@item.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="Sell" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Jual - @item.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="text-muted small">Dimiliki: @item.TotalUnits.ToString("0.######") @item.UnitLabel</p>
                                    <div class="mb-3">
                                        <label class="form-label">Jumlah Unit Dijual</label>
                                        <input type="text" name="units" class="form-control" placeholder="Contoh: 5 atau 0.25" inputmode="decimal" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Harga Jual per Unit</label>
                                        <input type="text" name="pricePerUnit" class="form-control buy-sell-price-input" placeholder="Harga jual" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="submit" class="btn btn-warning">Simpan</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- MODAL UPDATE HARGA -->
                <div class="modal fade" id="priceModal-@item.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="UpdatePrice" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Update Harga - @item.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <label class="form-label">Harga sekarang: Rp @item.CurrentPrice.ToString("N0", new CultureInfo("id-ID"))</label>
                                    <input type="text" name="newPrice" class="form-control buy-sell-price-input" placeholder="Harga terbaru" />
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="submit" class="btn btn-primary">Simpan</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <tr><td colspan="8" class="text-center">Belum ada investasi</td></tr>
        }
   </tbody>
</table>
    </div>

</div>

@section Scripts {
    <script>
        function formatNumber(value) { return value.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }
        function removeFormat(value) { return value.replace(/\./g, ""); }

        document.querySelectorAll('.buy-sell-price-input').forEach(function (input) {
            input.addEventListener('input', function () {
                let value = this.value.replace(/\D/g, "");
                this.value = value ? formatNumber(value) : "";
            });
            input.closest('form').addEventListener('submit', function () {
                input.value = removeFormat(input.value);
            });
        });
    </script>
}