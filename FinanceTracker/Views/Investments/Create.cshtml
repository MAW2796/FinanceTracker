@model FinanceTracker.Models.Investment

@{
    ViewData["Title"] = "Tambah Investasi";
}

<div class="container mt-4">

    <h3 class="fw-bold mb-4">Tambah Investasi</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold">Nama Investasi</label>
                        <input asp-for="Name" class="form-control" placeholder="Contoh: Emas Antam, BBCA, Bitcoin" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Type" class="form-label fw-semibold">Jenis</label>
                        <select asp-for="Type" class="form-select">
                            <option value="">-- Pilih Jenis --</option>
                            <option value="Saham">Saham</option>
                            <option value="Reksadana">Reksadana</option>
                            <option value="Emas">Emas</option>
                            <option value="Crypto">Crypto</option>
                            <option value="Deposito">Deposito</option>
                            <option value="Lainnya">Lainnya</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="UnitLabel" class="form-label fw-semibold">Label Unit</label>
                        <input asp-for="UnitLabel" class="form-control" placeholder="Contoh: Lot, Gram, Unit" />
                        <span asp-validation-for="UnitLabel" class="text-danger small"></span>
                        <small class="text-muted">Untuk Deposito, isi "1" sebagai unit tunggal</small>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Jumlah Unit Awal</label>
                        <input type="text" name="initialUnits" class="form-control" placeholder="Contoh: 10 atau 0.5" inputmode="decimal" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Harga Beli per Unit</label>
                        <input type="text" id="priceInput" name="initialPrice" class="form-control" placeholder="Contoh: 1.000.000" />
                    </div>

                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mt-3">
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">← Kembali</a>
                    <button type="submit" class="btn btn-primary px-4">Simpan</button>
                </div>

            </form>

        </div>
    </div>

    @section Scripts {
        <script>
            // Format ribuan HANYA untuk harga (Rupiah), bukan untuk unit (boleh desimal)
            function formatNumber(value) { return value.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }
            function removeFormat(value) { return value.replace(/\./g, ""); }
            const priceInput = document.getElementById("priceInput");
            priceInput.addEventListener("input", function () {
                let value = this.value.replace(/\D/g, "");
                this.value = value ? formatNumber(value) : "";
            });
            priceInput.closest("form").addEventListener("submit", function () {
                priceInput.value = removeFormat(priceInput.value);
            });
        </script>

        <partial name="_ValidationScriptsPartial" />
    }

</div>