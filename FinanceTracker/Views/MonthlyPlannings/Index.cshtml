@using System.Globalization
@{
    ViewData["Title"] = "Monthly Planning";

    var upcoming = ViewBag.Upcoming as List<FinanceTracker.Models.MonthlyPlanning>;
    var overdue = ViewBag.Overdue as List<FinanceTracker.Models.MonthlyPlanning>;
    var paid = ViewBag.Paid as List<FinanceTracker.Models.MonthlyPlanning>;
    var selectedMonthTotal = (decimal)ViewBag.SelectedMonthTotal;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
    <div>
        <h2 class="fw-bold mb-0">📅 Monthly Planning</h2>
        <strong>Total Planning Bulan Ini:</strong> Rp @selectedMonthTotal.ToString("N0", new CultureInfo("id-ID"))
    </div>

    <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
        + Tambah Planning
    </a>
</div>

<div class="mb-4 d-flex align-items-center gap-2">
    <label for="monthFilter" class="form-label fw-semibold mb-0">Lihat bulan:</label>
    <input type="month" class="form-control" id="monthFilter" value="@ViewBag.Month" style="max-width: 200px;" />
</div>

@{
    var projected = ViewBag.ProjectedInstallments as List<dynamic>;
    var projectedTotal = (decimal)ViewBag.ProjectedTotal;
}

@if (projected != null && projected.Any())
{
    <div class="alert alert-info">
        <strong>📊 Proyeksi Cicilan Bulan Ini (belum aktif, hanya estimasi)</strong>
        <table class="table table-sm mb-0 mt-2">
            <thead>
                <tr>
                    <th>Cicilan</th>
                    <th>Kategori</th>
                    <th>Jatuh Tempo (estimasi)</th>
                    <th>Jumlah</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in projected)
                {
                    <tr>
                        <td>@p.Title</td>
                        <td>@p.CategoryName</td>
                        <td>@(((DateTime)p.DueDate).ToString("dd MMM yyyy"))</td>
                        <td>Rp @(((decimal)p.Amount).ToString("N0", new CultureInfo("id-ID")))</td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="text-end mt-2">
            <strong>Total Proyeksi: Rp @projectedTotal.ToString("N0", new CultureInfo("id-ID"))</strong>
        </div>
        <small class="text-muted d-block mt-2">
            Cicilan ini akan otomatis masuk daftar Planning beneran saat sudah mendekati 15 hari jatuh tempo.
        </small>
    </div>
}

<!-- 🟡 UPCOMING -->
<h4 class="text-warning">Upcoming</h4>
<table class="table table-bordered table-hover">
    <thead class="table-warning">
        <tr>
            <th>Judul</th>
            <th>Jumlah</th>
            <th>Kategori</th>
            <th>Jatuh Tempo</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
        @if (upcoming != null && upcoming.Any())
        {
            foreach (var item in upcoming)
            {
                <tr>
                    <td>
                        @item.Title
                        @if (item.InstallmentId != null)
                        {
                            <span class="badge bg-info text-dark ms-1">Cicilan</span>
                        }
                    </td>
                    <td>Rp @item.Amount.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="MarkAsPaid" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            Bayar
                        </a>

                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        @* <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Yakin mau hapus?')">
                                Hapus
                            </button>
                        </form> *@
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            Hapus
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center">Tidak ada data</td></tr>
        }
    </tbody>
</table>

<!-- 🔴 OVERDUE -->
<h4 class="text-danger mt-5">Overdue</h4>
<table class="table table-bordered table-hover">
    <thead class="table-danger">
        <tr>
            <th>Judul</th>
            <th>Jumlah</th>
            <th>Kategori</th>
            <th>Jatuh Tempo</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
        @if (overdue != null && overdue.Any())
        {
            foreach (var item in overdue)
            {
                <tr class="table-danger">
                    <td>
                        @item.Title
                        @if (item.InstallmentId != null)
                        {
                            <span class="badge bg-info text-dark ms-1">Cicilan</span>
                        }
                    </td>
                    <td>Rp @item.Amount.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="MarkAsPaid" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            Bayar
                        </a>

                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        @* <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Yakin mau hapus?')">
                                Hapus
                            </button>
                        </form> *@
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            Hapus
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center">Tidak ada data</td></tr>
        }
    </tbody>
</table>

<!-- 🟢 PAID -->
<h4 class="text-success mt-5">Paid</h4>
<table class="table table-bordered table-hover">
    <thead class="table-success">
        <tr>
            <th>Judul</th>
            <th>Jumlah</th>
            <th>Kategori</th>
            <th>Dibayar</th>
        </tr>
    </thead>
    <tbody>
        @if (paid != null && paid.Any())
        {
            foreach (var item in paid)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>Rp @item.Amount.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.PaidDate?.ToString("dd MMM yyyy")</td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="4" class="text-center">Tidak ada data</td></tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        document.getElementById('monthFilter').addEventListener('change', function () {
            window.location.href = '@Url.Action("Index", "MonthlyPlannings")?month=' + this.value;
        });
    </script>
}