@model FinanceTracker.Models.Asset

@{
    ViewData["Title"] = "Tambah Aset";
}

<div class="container mt-4">

    <h3 class="fw-bold mb-4">Tambah Aset</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold">Nama Aset</label>
                        <input asp-for="Name" class="form-control" placeholder="Contoh: Tanah Bekasi" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CurrentValue" class="form-label fw-semibold">Nilai Saat Ini</label>
                        <input type="text" id="valueInput" name="CurrentValue" class="form-control" placeholder="Contoh: 150.000.000" />
                        <span asp-validation-for="CurrentValue" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Notes" class="form-label fw-semibold">Catatan (opsional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">← Kembali</a>
                    <button type="submit" class="btn btn-primary px-4">Simpan</button>
                </div>

            </form>

        </div>
    </div>

    @section Scripts {
        <script>
            function formatNumber(value) { return value.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }
            function removeFormat(value) { return value.replace(/\./g, ""); }
            const valueInput = document.getElementById("valueInput");
            valueInput.addEventListener("input", function () {
                let value = this.value.replace(/\D/g, "");
                this.value = value ? formatNumber(value) : "";
            });
            valueInput.closest("form").addEventListener("submit", function () {
                valueInput.value = removeFormat(valueInput.value);
            });
        </script>

        <partial name="_ValidationScriptsPartial" />
    }

</div>