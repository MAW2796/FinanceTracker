@using System.Globalization
@model List<FinanceTracker.Models.Asset>

@{
    ViewData["Title"] = "Aset";
    var total = (decimal)ViewBag.TotalValue;
}

@section Styles {
    <link rel="stylesheet" href="~/css/wealth.css" asp-append-version="true" />
}

<div class="wealth-page">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center page-header">
        <div>
            <h2 class="fw-bold mb-0">🏠 Aset</h2>
            <div class="mt-2">
                <span class="summary-pill">Total Nilai: Rp @total.ToString("N0", new CultureInfo("id-ID"))</span>
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            + Tambah Aset
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-card">
    <table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Nama</th>
            <th>Nilai Saat Ini</th>
            <th>Catatan</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>Rp @item.CurrentValue.ToString("N0", new CultureInfo("id-ID"))</td>
                    <td>@item.Notes</td>
                    <td>
                        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#updateModal-@item.Id">Update Nilai</button>
                        <a asp-action="History" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Riwayat</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Hapus</a>
                    </td>
                </tr>

                <!-- MODAL UPDATE NILAI -->
                <div class="modal fade" id="updateModal-@item.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="UpdateValue" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Update Nilai - @item.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <label class="form-label">Nilai saat ini: Rp @item.CurrentValue.ToString("N0", new CultureInfo("id-ID"))</label>
                                    <input type="text" name="newValue" class="form-control update-value-input" placeholder="Nilai baru" />
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="submit" class="btn btn-success">Simpan</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <tr><td colspan="4" class="text-center">Belum ada aset</td></tr>
        }
   </tbody>
</table>
    </div>

</div>

@section Scripts {
    <script>
        function formatNumber(value) { return value.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }
        function removeFormat(value) { return value.replace(/\./g, ""); }

        document.querySelectorAll('.update-value-input').forEach(function (input) {
            input.addEventListener('input', function () {
                let value = this.value.replace(/\D/g, "");
                this.value = value ? formatNumber(value) : "";
            });
            input.closest('form').addEventListener('submit', function () {
                input.value = removeFormat(input.value);
            });
        });
    </script>
}