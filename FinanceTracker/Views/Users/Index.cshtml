@model IEnumerable<FinanceTracker.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">User Management</h2>
            <small class="text-muted">Kelola semua pengguna</small>
        </div>

        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            + Tambah User
        </a>
    </div>

    <!-- TABLE -->
    <div class="table-container">
        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Nama</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Tanggal Dibuat</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Belum ada user 😢
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- NAME -->
                                <td class="fw-semibold">
                                    @item.Name
                                </td>

                                <!-- EMAIL -->
                                <td>
                                    @item.Email
                                </td>

                                <!-- ROLE -->
                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border">
                                            Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border">
                                            User
                                        </span>
                                    }
                                </td>

                                <!-- DATE -->
                                <td>
                                    @item.CreatedDate.ToString("dd MMM yyyy")
                                </td>

                                <!-- ACTION -->
                                <td>
                                    <div class="d-flex flex-wrap gap-1">

                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning">Edit</a>

                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info">Detail</a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger">Delete</a>

                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>