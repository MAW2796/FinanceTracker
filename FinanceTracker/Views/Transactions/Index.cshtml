@using System.Globalization
@model IEnumerable<FinanceTracker.Models.Transaction>

@{
    ViewData["Title"] = "Transactions";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Finance Tracker</h2>
            <small class="text-muted">Kelola pemasukan & pengeluaran kamu</small>
        </div>

        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            + Tambah Transaksi
        </a>
    </div>

    <!-- DASHBOARD -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-4">
            <div class="card summary-card income">
                <div class="card-body">
                    <p class="label">Total Income</p>
                    <h5>Rp @ViewBag.TotalIncome.ToString("N0", new CultureInfo("id-ID"))</h5>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card summary-card expense">
                <div class="card-body">
                    <p class="label">Total Expense</p>
                    <h5>Rp @ViewBag.TotalExpense.ToString("N0", new CultureInfo("id-ID"))</h5>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card summary-card balance">
                <div class="card-body">
                    <p class="label">Balance</p>
                    <h5>
                        Rp @((ViewBag.TotalIncome - ViewBag.TotalExpense).ToString("N0", new CultureInfo("id-ID")))
                    </h5>
                </div>
            </div>
        </div>

    </div>

    <!-- FILTER -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-2">

                <div class="col-12 col-md-4">
                    <input type="text" name="search" class="form-control"
                           value="@ViewBag.Search"
                           placeholder="Cari deskripsi..." />
                </div>

                <div class="col-12 col-md-3">
                    <input type="month" name="month" class="form-control"
                           value="@ViewBag.Month" />
                </div>

                <div class="col-6 col-md-2">
                    <button class="btn btn-outline-primary w-100">
                        Filter
                    </button>
                </div>

                <div class="col-6 col-md-2">
                    <a href="/Transactions" class="btn btn-outline-secondary w-100">
                        Reset
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Amount</th>
                        <th class="d-none d-md-table-cell">Description</th>
                        <th>Category</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Belum ada transaksi 😢
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.Date.ToString("dd MMM yyyy")</td>

                                <td>
                                    @if (item.Category.Type == "Income")
                                    {
                                        <span class="text-success fw-semibold">
                                            + Rp @item.Amount.ToString("N0", new CultureInfo("id-ID"))
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-semibold">
                                            - Rp @item.Amount.ToString("N0", new CultureInfo("id-ID"))
                                        </span>
                                    }
                                </td>

                                <td class="d-none d-md-table-cell">
                                    @item.Description
                                </td>

                                <td>
                                    @if (item.Category.Type == "Income")
                                    {
                                        <span class="badge bg-success-subtle text-success border">
                                            @item.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border">
                                            @item.Category.Name
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning">Edit</a>

                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info">Detail</a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>
    <!-- INFO -->
    <p class="text-center text-muted small mb-2">
        Menampilkan halaman <b>@ViewBag.CurrentPage</b> dari <b>@ViewBag.TotalPages</b>
    </p>

   @*  <p class="text-muted small text-center mt-3">
        Halaman @ViewBag.CurrentPage dari @ViewBag.TotalPages
    </p> *@

    <!-- PAGINATION -->
    <nav>
        <ul class="pagination justify-content-center flex-wrap">

            <!-- PREV -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search&month=@ViewBag.Month">
                    «
                </a>
            </li>

            @{
                int start = Math.Max(1, ViewBag.CurrentPage - 2);
                int end = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
            }

            <!-- NUMBER -->
            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       href="?page=@i&search=@ViewBag.Search&month=@ViewBag.Month">
                        @i
                    </a>
                </li>
            }

            <!-- NEXT -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search&month=@ViewBag.Month">
                    »
                </a>
            </li>

        </ul>
    </nav>

</div>