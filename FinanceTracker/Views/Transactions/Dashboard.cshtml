@model List<FinanceTracker.Models.Transaction>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">Dashboard Keuangan</h2>

    <!-- SUMMARY CARDS -->
    <div class="col-md-4">
        <label class="form-label fw-semibold">Filter Bulan</label>
        <div class="d-flex align-items-center">
            <input type="month" class="form-control" id="monthFilter" value="@ViewBag.Month" style="max-width: 200px;" />
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">

        <!-- SALDO -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Saldo</p>
                        <h3 class="text-primary fw-bold mb-0">
                            Rp @ViewBag.Balance.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-primary">
                        💳
                    </div>

                </div>
            </div>
        </div>

        <!-- PEMASUKAN -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Pemasukan</p>
                        <h3 class="text-success fw-bold mb-0">
                            Rp @ViewBag.TotalIncome.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-success">
                        💰
                    </div>

                </div>
            </div>
        </div>

        <!-- PENGELUARAN -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Pengeluaran</p>
                        <h3 class="text-danger fw-bold mb-0">
                            Rp @ViewBag.TotalExpense.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-danger">
                        💸
                    </div>

                </div>
            </div>
        </div>

    </div>


    <div class="row">

        <!-- BAR CHART -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Grafik Keuangan</h5>
                    <canvas id="financeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- PIE CHART -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Distribusi Pengeluaran</h5>
                    <canvas id="expensePieChart"></canvas>
                </div>
            </div>
        </div>

    </div>

    @section Scripts{

        <script>

            document.addEventListener("DOMContentLoaded", function () {

                // BAR CHART

                const barCtx = document.getElementById('financeChart');

                new Chart(barCtx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.BarLabels)),
                        datasets: [
                            {
                                label: 'Pemasukan',
                                data: @Html.Raw(Json.Serialize(ViewBag.BarIncomeData)),
                                backgroundColor: 'rgba(25,135,84,0.7)'
                            },
                            {
                                label: 'Pengeluaran',
                                data: @Html.Raw(Json.Serialize(ViewBag.BarExpenseData)),
                                backgroundColor: 'rgba(220,53,69,0.7)'
                            }
                        ]
                    }
                });

                // PIE CHART

                const pieCtx = document.getElementById('expensePieChart');

                new Chart(pieCtx, {
                    type: 'pie',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ExpenseCategoryLabels)),
                        datasets: [{
                            data: @Html.Raw(Json.Serialize(ViewBag.ExpenseCategoryValues)),
                            backgroundColor: [
                                '#0d6efd',
                                '#198754',
                                '#ffc107',
                                '#dc3545',
                                '#6c757d',
                                '#20c997',
                                '#fd7e14'
                            ]
                        }]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        plugins: {
                            legend: {
                                position: 'bottom'
                            },
                            datalabels: {
                                color: '#fff',
                                font: {
                                    weight: 'bold',
                                    size: 14
                                },
                                formatter: (value, context) => {

                                    let dataArr = context.chart.data.datasets[0].data;
                                    let sum = dataArr.reduce((a, b) => a + b, 0);
                                    let percentage = (value * 100 / sum).toFixed(1) + "%";

                                    return percentage;
                                }
                            }
                        }
                    }
                });
            });

            document.getElementById('monthFilter').addEventListener('change', function () {
                const input = this;
                input.disabled = true;

                const loadingText = document.createElement('span');
                loadingText.id = 'monthLoadingText';
                loadingText.className = 'text-muted small ms-2';
                loadingText.innerText = 'Memuat...';
                input.insertAdjacentElement('afterend', loadingText);

                window.location.href = '@Url.Action("Dashboard", "Transactions")?month=' + input.value;
            });

        </script>

    }


    <!-- RECENT TRANSACTIONS -->
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h5 class="mb-3">Transaksi Terbaru</h5>

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>Tanggal</th>
                        <th>Kategori</th>
                        <th>Deskripsi</th>
                        <th class="text-end">Jumlah</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var t in Model.OrderByDescending(t => t.Date).Take(5))
                    {
                        <tr>
                            <td>@t.Date.ToString("d MMM yyyy")</td>
                            <td>@t.Category?.Name</td>
                            <td>@t.Description</td>
                            @if (t.Category?.Type == "Income")
                            {
                                <td class="text-success text-end">+ Rp @t.Amount.ToString("N0").Replace(",", ".")</td>
                            }
                            else
                            {
                                <td class="text-danger text-end">- Rp @t.Amount.ToString("N0").Replace(",", ".")</td>
                            }
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>