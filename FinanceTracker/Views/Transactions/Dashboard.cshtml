@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">Dashboard Keuangan</h2>

    <!-- SUMMARY CARDS -->
    <div class="row mb-4">

        <!-- FILTER BULAN -->
        <div class="col-md-4">
            <label class="form-label fw-semibold">Filter Bulan</label>
            <select class="form-select" id="monthFilter">
                <option value="1">Januari</option>
                <option value="2">Februari</option>
                <option value="3" selected>Maret</option>
                <option value="4">April</option>
                <option value="5">Mei</option>
                <option value="6">Juni</option>
                <option value="7">Juli</option>
                <option value="8">Agustus</option>
                <option value="9">September</option>
                <option value="10">Oktober</option>
                <option value="11">November</option>
                <option value="12">Desember</option>
            </select>
        </div>

    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">

        <!-- SALDO -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Saldo</p>
                        <h3 class="text-primary fw-bold mb-0">
                            Rp @ViewBag.Balance.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-primary">
                        💳
                    </div>

                </div>
            </div>
        </div>

        <!-- PEMASUKAN -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Pemasukan</p>
                        <h3 class="text-success fw-bold mb-0">
                            Rp @ViewBag.TotalIncome.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-success">
                        💰
                    </div>

                </div>
            </div>
        </div>

        <!-- PENGELUARAN -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <p class="text-muted mb-1">Pengeluaran</p>
                        <h3 class="text-danger fw-bold mb-0">
                            Rp @ViewBag.TotalExpense.ToString("N0").Replace(",", ".")
                        </h3>
                    </div>

                    <div class="icon-circle bg-danger">
                        💸
                    </div>

                </div>
            </div>
        </div>

    </div>


    <div class="row">

        <!-- BAR CHART -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Grafik Keuangan</h5>
                    <canvas id="financeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- PIE CHART -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Distribusi Pengeluaran</h5>
                    <canvas id="expensePieChart"></canvas>
                </div>
            </div>
        </div>

    </div>

    @section Scripts{

        <script>

            document.addEventListener("DOMContentLoaded", function () {

                // BAR CHART
                const barCtx = document.getElementById('financeChart');

                new Chart(barCtx, {
                    type: 'bar',
                    data: {
                        labels: ['Jan','Feb','Mar'],
                        datasets: [
                            {
                                label: 'Pemasukan',
                                data: [4000000,4500000,5000000],
                                backgroundColor: 'rgba(25,135,84,0.7)'
                            },
                            {
                                label: 'Pengeluaran',
                                data: [2500000,3200000,3200000],
                                backgroundColor: 'rgba(220,53,69,0.7)'
                            }
                        ]
                    }
                });

                // PIE CHART

                const pieCtx = document.getElementById('expensePieChart');

                new Chart(pieCtx, {
                    type: 'pie',
                    data: {
                        labels: ['Makan', 'Transport', 'Belanja', 'Tagihan', 'Lainnya'],
                        datasets: [{
                            data: [1200000, 500000, 800000, 400000, 300000],
                            backgroundColor: [
                                '#0d6efd',
                                '#198754',
                                '#ffc107',
                                '#dc3545',
                                '#6c757d'
                            ]
                        }]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        plugins: {
                            legend: {
                                position: 'bottom'
                            },
                            datalabels: {
                                color: '#fff',
                                font: {
                                    weight: 'bold',
                                    size: 14
                                },
                                formatter: (value, context) => {

                                    let dataArr = context.chart.data.datasets[0].data;
                                    let sum = dataArr.reduce((a, b) => a + b, 0);
                                    let percentage = (value * 100 / sum).toFixed(1) + "%";

                                    return percentage;
                                }
                            }
                        }
                    }
                });
            });

        </script>

    }


    <!-- RECENT TRANSACTIONS -->
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h5 class="mb-3">Transaksi Terbaru</h5>

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>Tanggal</th>
                        <th>Kategori</th>
                        <th>Deskripsi</th>
                        <th class="text-end">Jumlah</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>1 Mar 2026</td>
                        <td>Gaji</td>
                        <td>Gaji Bulanan</td>
                        <td class="text-success text-end">+ Rp 5.000.000</td>
                    </tr>

                    <tr>
                        <td>2 Mar 2026</td>
                        <td>Makan</td>
                        <td>Makan Siang</td>
                        <td class="text-danger text-end">- Rp 35.000</td>
                    </tr>

                    <tr>
                        <td>3 Mar 2026</td>
                        <td>Transport</td>
                        <td>Bensin</td>
                        <td class="text-danger text-end">- Rp 50.000</td>
                    </tr>

                </tbody>

            </table>

        </div>
    </div>

</div>