@model FinanceTracker.Models.User

@{
    ViewData["Title"] = "Register";
}

<h2>Register</h2>

<form method="post">

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="Password" type="password" />
    </div>

    <button type="submit">Register</button>

</form>