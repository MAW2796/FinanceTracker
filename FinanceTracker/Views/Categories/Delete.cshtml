@model FinanceTracker.Models.Category

@{
    ViewData["Title"] = "Hapus Kategori";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h3 class="fw-bold text-danger mb-0">Hapus Kategori</h3>
        <small class="text-muted">Tindakan ini tidak bisa dibatalkan</small>
    </div>

    <!-- CARD -->
    <div class="card shadow-sm border-danger">
        <div class="card-body">

            <!-- WARNING -->
            <div class="alert alert-danger">
                ⚠️ Apakah kamu yakin ingin menghapus kategori ini?
            </div>

            <div class="row g-3">

                <!-- NAME -->
                <div class="col-md-6">
                    <label class="text-muted small">Nama</label>
                    <div class="fw-semibold">
                        @Model.Name
                    </div>
                </div>

                <!-- TYPE -->
                <div class="col-md-6">
                    <label class="text-muted small">Tipe</label>
                    <div>
                        @if (Model.Type == "Income")
                        {
                            <span class="badge bg-success-subtle text-success border">
                                Income
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger border">
                                Expense
                            </span>
                        }
                    </div>
                </div>

            </div>

            <!-- ACTION -->
            <div class="mt-4 d-flex justify-content-between">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    ← Batal
                </a>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4">
                        Hapus
                    </button>
                </form>

            </div>

        </div>
    </div>

</div>