@model FinanceTracker.Models.Category

@{
    ViewData["Title"] = "Edit Kategori";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h3 class="fw-bold mb-0">Edit Kategori</h3>
        <small class="text-muted">Perbarui kategori transaksi</small>
    </div>

    <!-- CARD -->
    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Edit" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <!-- NAME -->
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control"
                               placeholder="Contoh: Gaji, Makan, Transport" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- TYPE -->
                    <div class="col-md-6">
                        <label asp-for="Type" class="form-label fw-semibold"></label>
                        <select asp-for="Type" class="form-select">
                            <option value="">-- Pilih Tipe --</option>
                            <option value="Income">Income</option>
                            <option value="Expense">Expense</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                </div>

                <!-- ACTION -->
                <div class="mt-4 d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        ← Kembali
                    </a>

                    <button type="submit" class="btn btn-primary px-4">
                        Update
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>