@model IEnumerable<FinanceTracker.Models.Category>

@{
    ViewData["Title"] = "Kategori";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Kategori</h2>
            <small class="text-muted">Kelola kategori transaksi</small>
        </div>

        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            + Tambah Kategori
        </a>
    </div>

    <!-- Filter -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-2">

                <!-- SEARCH -->
                <div class="col-12 col-md-4">
                    <input type="text" name="search" class="form-control"
                           value="@ViewBag.Search"
                           placeholder="Cari kategori..." />
                </div>

                <!-- TYPE -->
                <div class="col-12 col-md-3">
                    <select name="type" class="form-select">
                        <option value="">Semua Tipe</option>
                        <option value="Income" selected="@(ViewBag.Type == "Income")">Income</option>
                        <option value="Expense" selected="@(ViewBag.Type == "Expense")">Expense</option>
                    </select>
                </div>

                <!-- BUTTON -->
                <div class="col-6 col-md-2">
                    <button class="btn btn-outline-primary w-100">
                        Filter
                    </button>
                </div>

                <div class="col-6 col-md-2">
                    <a href="/Categories" class="btn btn-outline-secondary w-100">
                        Reset
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-container">
        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Nama</th>
                        <th>Tipe</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                Belum ada kategori 😢
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- NAME -->
                                <td class="fw-semibold">
                                    @item.Name
                                </td>

                                <!-- TYPE -->
                                <td>
                                    @if (item.Type == "Income")
                                    {
                                        <span class="badge bg-success-subtle text-success border">
                                            Income
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border">
                                            Expense
                                        </span>
                                    }
                                </td>

                                <!-- ACTION -->
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning">Edit</a>

                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info">Detail</a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>
    </div>

    <p class="text-center small text-muted mt-3">
        Halaman @ViewBag.CurrentPage dari @ViewBag.TotalPages
    </p>

    <nav>
        <ul class="pagination justify-content-center flex-wrap">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search&type=@ViewBag.Type">
                    «
                </a>
            </li>

            @{
                int start = Math.Max(1, ViewBag.CurrentPage - 2);
                int end = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
            }

            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       href="?page=@i&search=@ViewBag.Search&type=@ViewBag.Type">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search&type=@ViewBag.Type">
                    »
                </a>
            </li>

        </ul>
    </nav>

</div>